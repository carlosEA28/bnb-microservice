# Kong JWT Keys Configuration
# Copy this file to .env and fill in your actual keys

# First Cognito Key
JWT_KEY_1=your_jwt_key_1_here
RSA_PUBLIC_KEY_1="-----BEGIN PUBLIC KEY-----\nyour_public_key_1_here\n-----END PUBLIC KEY-----"

# Second Cognito Key
JWT_KEY_2=your_jwt_key_2_here
RSA_PUBLIC_KEY_2="-----BEGIN PUBLIC KEY-----\nyour_public_key_2_here\n-----END PUBLIC KEY-----"
